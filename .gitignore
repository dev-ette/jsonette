# macOS
.DS_Store

# Rust — target/ is also in engine/.gitignore; root entry is a safety net
engine/target/
target/
# Library crates don't commit Cargo.lock — downstream consumers manage their own
engine/Cargo.lock
Cargo.lock

# Xcode / Swift
macos/*.xcodeproj/xcuserdata/
macos/*.xcodeproj/project.xcworkspace/xcuserdata/
macos/*.xcworkspace/xcuserdata/
macos/*.xcworkspace/xcshareddata/
**/DerivedData/
*.ipa
*.xcarchive
*.xcresult

# Swift Package Manager (used by macos/ dependencies e.g. CodeEditSourceEditor)
macos/.build/

# IDE
# JetBrains / RustRover
.idea/workspace.xml
.idea/tasks.xml
.idea/usage.statistics.xml
.idea/dictionary.xml
.idea/shelf/
.idea/httpRequests/
.idea/copilot/
*.iml
.vscode/

# Generated UniFFI bindings
macos/generated/

# Architecture
# Comment out html-docs/ to allow tracking StarUML architecture exports in Git
# html-docs/

# Generated engine documentation
docs/engine-docs/
engine-docs/
