{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "runArgs",
      "type": "promptString",
      "description": "Arguments for cargo run",
      "default": ""
    }
  ],
  "tasks": [
    {
      "label": "Build (Debug)",
      "type": "shell",
      "command": "cargo build --workspace",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "Build (Release)",
      "type": "shell",
      "command": "cargo build --workspace --release",
      "group": "build",
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "Run",
      "type": "shell",
      "command": "cargo run -p jsonette",
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "Run with args",
      "type": "shell",
      "command": "cargo run -p jsonette -- ${input:runArgs}",
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "Check (Warnings)",
      "type": "shell",
      "command": "cargo clippy --workspace --all-targets --all-features -- -D warnings",
      "problemMatcher": ["$rustc"],
      "group": "test"
    },
    {
      "label": "Format Check",
      "type": "shell",
      "command": "cargo fmt --all -- --check",
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "Format Fix",
      "type": "shell",
      "command": "cargo fmt --all",
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "Test",
      "type": "shell",
      "command": "cargo test --workspace",
      "group": "test",
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "Test Coverage (tarpaulin)",
      "type": "shell",
      "command": "cargo tarpaulin --workspace",
      "problemMatcher": ["$rustc"],
      "detail": "Requires cargo-tarpaulin: cargo install cargo-tarpaulin"
    },
    {
      "label": "Generate Docs",
      "type": "shell",
      "command": "cargo doc --workspace --no-deps",
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "Generate & Open Docs",
      "type": "shell",
      "command": "cargo doc --workspace --no-deps --open",
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "Publish to crates.io",
      "type": "shell",
      "command": "cargo publish -p jsonette-core && cargo publish -p jsonette",
      "problemMatcher": ["$rustc"],
      "detail": "Publishes core library first, then the CLI tool."
    }
  ]
}
